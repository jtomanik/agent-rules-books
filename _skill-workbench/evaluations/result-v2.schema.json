{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "answer",
    "selected_project_skills",
    "consulted_files",
    "consulted_reference_sections",
    "reference_mode"
  ],
  "properties": {
    "answer": {
      "type": "string"
    },
    "selected_project_skills": {
      "description": "Observed repository book skills whose SKILL.md files were consulted. Acceptance requires the case's required skills to be a subset; additional selections are permitted.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "consulted_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consulted_reference_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "sections"],
        "properties": {
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "reference_mode": {
      "description": "Observed highest disclosure tier used during the run; exact focused-section counts are diagnostic rather than an acceptance requirement.",
      "type": "string",
      "enum": ["none", "ordinary", "focused", "comprehensive"]
    }
  }
}
